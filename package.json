{
  "name": "shelfmaster-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node server.js",
    "build": "vite build",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -n SERVER,ELECTRON -c blue,magenta \"node server.js\" \"wait-on http://127.0.0.1:5000 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron": "npm run build && cross-env NODE_ENV=production electron .",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.shelfmaster.app",
    "productName": "ShelfMaster",
    "files": [
      "electron/**/*",
      "server.js",
      "dist/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/uploads",
        "to": "uploads",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/shelfmaster_logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/shelfmaster_logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/shelfmaster_logo.png"
    },
    "asar": true,
    "asarUnpack": [
      "server.js",
      "node_modules/mysql2/**/*",
      "node_modules/bcryptjs/**/*"
    ]
  },
  "dependencies": {
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "mysql2": "^3.22.2",
    "react": "^19.2.5",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  }
}
